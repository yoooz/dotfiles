{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Read(*)",
      "Bash(rg:*)",
      "Bash(git grep:*)",
      "Bash(go test:*)",
      "Bash(go build:*)",
      "Bash(go mod tidy:*)",
      "Bash(go mod graph:*)",
      "Bash(go mod why:*)",
      "Bash(go list:*)",
      "Bash(go doc:*)",
      "Bash(npm outdated:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(cat:*)",
      "Bash(xargs:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(wc:*)",
      "Bash(echo:*)",
      "Bash(tree:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh issue view:*)",
      "Bash(git ls-tree:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(git mv:*)",
      "Bash(git add:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(ln:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:blog.shibayu36.org)",
      "mcp__serena__search_for_pattern",
      "mcp__serena__find_symbol",
      "mcp__serena__list_dir",
      "mcp__serena__get_symbols_overview",
      "mcp__serena__find_referencing_symbols",
      "Bash(gws schema:*)",
      "Bash(gws docs documents get:*)",
      "Bash(gws drive files get:*)",
      "Bash(gws drive files list:*)",
      "Bash(gws drive files export:*)",
      "Bash(gws drive files download:*)",
      "Bash(gws drive comments get:*)",
      "Bash(gws drive comments list:*)",
      "Bash(gws sheets spreadsheets get:*)",
      "Bash(gws sheets spreadsheets getByDataFilter:*)",
      "Bash(gws sheets spreadsheets values get:*)",
      "Bash(gws sheets spreadsheets values batchGet:*)",
      "Bash(gws sheets spreadsheets values batchGetByDataFilter:*)",
      "Bash(gws sheets spreadsheets developerMetadata get:*)",
      "Bash(gws sheets spreadsheets developerMetadata search:*)",
      "Bash(gws sheets +read:*)",
      "Bash(gws slides presentations get:*)",
      "Bash(gws slides presentations pages get:*)",
      "Bash(gws slides presentations pages getThumbnail:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Read(.env*)",
      "Read(id_rsa)",
      "Read(id_dsa)",
      "Read(id_ed25519)"
    ],
    "additionalDirectories": [
      "~/yoooz_vault/"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/scripts/statusline.js"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "preferredNotifChannel": "terminal_bell"
}
